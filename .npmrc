engine-strict=true
auto-install-peers=true
strict-peer-dependencies=false
# pnpm 11 verifies node_modules is in sync before running any script via `pnpm exec`.
# That check chokes on the ignored-builds warning (esbuild ships its binary as an
# optional-dep, so the build script is redundant anyway). Skip the pre-check.
verify-deps-before-run=false
